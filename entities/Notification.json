{
  "name": "Notification",
  "type": "object",
  "properties": {
    "message": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "warning",
        "info",
        "success",
        "error"
      ]
    },
    "is_read": {
      "type": "boolean",
      "default": false
    },
    "related_post_id": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Optional additional detail for the notification"
    }
  },
  "required": [
    "message",
    "type"
  ]
}