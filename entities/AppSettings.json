{
  "name": "AppSettings",
  "type": "object",
  "properties": {
    "about_what": {
      "type": "string",
      "description": "What is Hamster"
    },
    "about_who_for": {
      "type": "string",
      "description": "Who is it for"
    },
    "about_who_builds": {
      "type": "string",
      "description": "Who builds Hamster"
    },
    "contact_email": {
      "type": "string",
      "description": "Contact email address"
    },
    "instagram_link": {
      "type": "string",
      "description": "Instagram profile URL"
    },
    "linkedin_link": {
      "type": "string",
      "description": "LinkedIn profile URL"
    },
    "tiktok_link": {
      "type": "string",
      "description": "TikTok profile URL"
    },
    "x_link": {
      "type": "string",
      "description": "X (Twitter) profile URL"
    },
    "additional_links": {
      "type": "array",
      "description": "Additional custom links (label + url pairs)",
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      }
    },
    "singleton_key": {
      "type": "string",
      "description": "Used to identify the single settings record",
      "default": "main"
    }
  },
  "required": [
    "singleton_key"
  ]
}