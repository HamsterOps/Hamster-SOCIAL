{
  "name": "AutomationRule",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Rule name"
    },
    "description": {
      "type": "string",
      "description": "What this rule does"
    },
    "trigger_type": {
      "type": "string",
      "enum": [
        "time_based",
        "event_based"
      ],
      "description": "How the rule triggers"
    },
    "trigger_config": {
      "type": "string",
      "description": "Trigger configuration details"
    },
    "condition": {
      "type": "string",
      "description": "Condition to check"
    },
    "action": {
      "type": "string",
      "description": "Action to perform"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "last_triggered": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "name",
    "trigger_type",
    "action"
  ]
}